# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# SUPABASE_URL: The connection URL for your Supabase backend instance.
SUPABASE_URL=
# VITE_SUPABASE_URL: Optional client-side fallback if not loaded dynamically via backend API.
VITE_SUPABASE_URL=

# SUPABASE_ANON_KEY: Client-safe public anonymous key for authentication & subscriptions.
SUPABASE_ANON_KEY=
# VITE_SUPABASE_ANON_KEY: Optional client-side fallback.
VITE_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Highly sensitive service role key used server-side for admin bypass.
SUPABASE_SERVICE_ROLE_KEY=

# GOOGLE_MAPS_API_KEY: Standard API key used to load Google Maps Platform scripts and components.
GOOGLE_MAPS_API_KEY=
# VITE_GOOGLE_MAPS_API_KEY: Client-side Google Maps API key fallback.
VITE_GOOGLE_MAPS_API_KEY=
